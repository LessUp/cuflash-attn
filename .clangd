# clangd Language Server Configuration for CuFlash-Attn
# This enables accurate C++/CUDA code intelligence in any LSP-compatible editor
# (VS Code + clangd extension, Neovim, CLion, etc.)
#
# Prerequisites: cmake --preset release to generate compile_commands.json

CompileFlags:
  # Point to the compile_commands.json generated by CMake
  CompilationDatabase: build/release

  # Add CUDA and common include paths when compile_commands.json is unavailable
  Add:
    - -I./include
    - -I./src/kernels
    - --cuda-gpu-arch=sm_86
    - -x
    - cuda

Diagnostics:
  # Suppress CUDA-specific warnings that clangd can't resolve
  Suppress:
    - cuda_device_builtin_vector_types
    - unknown_pragma
  UnusedIncludes: Strict
  ClangTidy:
    Add:
      - bugprone-*
      - modernize-use-nullptr
      - modernize-use-override
      - performance-*
    Remove:
      - bugprone-narrowing-conversions
      - modernize-use-trailing-return-type
      - cppcoreguidelines-pro-type-reinterpret-cast
      - cppcoreguidelines-pro-bounds-pointer-arithmetic

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

Hover:
  ShowAKA: true

Index:
  Background: Build
